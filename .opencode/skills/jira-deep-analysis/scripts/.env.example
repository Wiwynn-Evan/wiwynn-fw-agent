# jira-deep-analysis skill 輔助 scripts 認證設定範本
# 複製此檔案為 .env 並填入實際值
# ⚠️  .env 檔案包含機敏資訊，請勿提交至 Git！

# ============================================================
# GitHub API Token
# 申請位置：https://github.com/settings/tokens
# 建議使用 Fine-Grained Token（前綴：github_pat_）
# 最低權限：Contents: read-only（用於 code search 和讀取檔案）
# ============================================================
GITHUB_TOKEN=your_github_token_here

# ============================================================
# JIRA API
# 申請位置：https://id.atlassian.com/manage-profile/security/api-tokens
# ============================================================
JIRA_URL=https://your-company.atlassian.net
JIRA_USERNAME=your.email@company.com
JIRA_API_TOKEN=YOUR_JIRA_API_TOKEN_HERE
